{
  "entities": {
    "Client": {
      "title": "Client",
      "description": "Personal information for a wellness client",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name" },
        "phone": { "type": "string", "description": "Contact phone number" },
        "address": { "type": "string", "description": "Home address" },
        "searchName": { "type": "string", "description": "Lowercase name for searching" },
        "ownerId": { "type": "string", "description": "UID of the user who owns this client record" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "phone", "searchName", "ownerId"]
    },
    "Treatment": {
      "title": "Treatment",
      "description": "Details of a specific treatment session",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date-time" },
        "treatmentName": { "type": "string", "description": "Name of the treatment" },
        "productUsage": { "type": "string", "description": "Products used or energy level" },
        "doctorName": { "type": "string", "description": "Doctor who performed the treatment" },
        "ownerId": { "type": "string", "description": "UID of the user who owns this treatment" },
        "clientName": { "type": "string", "description": "Patient name at time of log" },
        "clientPhone": { "type": "string", "description": "Patient phone at time of log" },
        "followUpDate": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" },
        "products": { "type": "array", "description": "List of products sold/used" },
        "serviceMRP": { "type": "number", "description": "MRP for the clinical service" },
        "serviceDiscount": { "type": "number", "description": "Discount on the service" },
        "serviceDiscountType": { "type": "string", "enum": ["percentage", "fixed"] },
        "totalAmount": { "type": "number", "description": "Total billable amount" },
        "paidAmount": { "type": "number", "description": "Amount paid by user" },
        "balanceAmount": { "type": "number", "description": "Remaining balance" },
        "paymentMethod": { "type": "string", "enum": ["Cash", "PhonePe", "POS", "POS QR Code"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["date", "treatmentName", "ownerId", "createdAt", "doctorName"]
    }
  },
  "firestore": {
    "/clients/{clientId}": {
      "schema": "Client",
      "description": "Collection of clients"
    },
    "/clients/{clientId}/treatments/{treatmentId}": {
      "schema": "Treatment",
      "description": "Subcollection of treatments for a specific client"
    }
  }
}
