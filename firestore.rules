rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function docOwner(doc) { return isSignedIn() && doc.ownerId == request.auth.uid; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Specific Collection Rules ---

    match /test/{docId} {
      allow read: if isSignedIn();
    }

    match /leads/{leadId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid 
        && (incoming().updatedAt == request.time || !('updatedAt' in incoming()));
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid
        && (incoming().updatedAt == request.time || !('updatedAt' in incoming()))
        && (incoming().ownerId == resource.data.ownerId);
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /{path=**}/treatments/{treatmentId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /clients/{clientId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid 
        && (incoming().updatedAt == request.time || !('updatedAt' in incoming()));
      
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid
        && (incoming().updatedAt == request.time || !('updatedAt' in incoming()))
        && (incoming().ownerId == resource.data.ownerId);

      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;

      match /treatments/{treatmentId} {
        function parentOwner() {
          return get(/databases/$(database)/documents/clients/$(clientId)).data.ownerId == request.auth.uid;
        }

        function isValidTreatment() {
          let data = incoming();
          return data.treatmentName is string 
            && (!('totalAmount' in data) || data.totalAmount is number)
            && (!('paidAmount' in data) || data.paidAmount is number)
            && (!('balanceAmount' in data) || data.balanceAmount is number)
            && (!('serviceMRP' in data) || data.serviceMRP is number)
            && (!('serviceDiscount' in data) || data.serviceDiscount is number)
            && (!('serviceDiscountType' in data) || data.serviceDiscountType in ['percentage', 'fixed'])
            && (!('doctorName' in data) || data.doctorName is string)
            && (!('notes' in data) || data.notes is string)
            && (!('productUsage' in data) || data.productUsage is string)
            && (!('products' in data) || data.products is list)
            && (!('services' in data) || data.services is list)
            && (!('paymentMethod' in data) || data.paymentMethod in ['Cash', 'PhonePe', 'POS', 'POS QR Code']);
        }

        allow read: if isSignedIn() && (resource.data.ownerId == request.auth.uid || parentOwner());
        
        allow create: if isSignedIn() && parentOwner() 
          && (incoming().ownerId == request.auth.uid)
          && (incoming().updatedAt == request.time || !('updatedAt' in incoming()))
          && isValidTreatment();
          
        allow update: if isSignedIn() && (resource.data.ownerId == request.auth.uid || parentOwner())
          && (incoming().updatedAt == request.time || !('updatedAt' in incoming()))
          && (incoming().ownerId == resource.data.ownerId)
          && isValidTreatment();

        allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || parentOwner());
      }
    }
  }
}
