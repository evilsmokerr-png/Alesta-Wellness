rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function docOwner(doc) { return isSignedIn() && doc.ownerId == request.auth.uid; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Specific Collection Rules ---

    match /test/{docId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/treatments/{treatmentId} {
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /clients/{clientId} {
      allow get: if docOwner(existing());
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid 
        && incoming().updatedAt == request.time;
      
      allow update: if docOwner(existing()) 
        && (incoming().updatedAt == request.time || !('updatedAt' in incoming()) || incoming().updatedAt == existing().updatedAt)
        && (incoming().ownerId == existing().ownerId);

      allow delete: if docOwner(existing());

      match /treatments/{treatmentId} {
        function parentOwner() {
          return get(/databases/$(database)/documents/clients/$(clientId)).data.ownerId == request.auth.uid;
        }

        allow list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || parentOwner());
        allow get: if isSignedIn() && (resource.data.ownerId == request.auth.uid || parentOwner());
        
        allow create: if isSignedIn() && parentOwner() 
          && incoming().ownerId == request.auth.uid
          && incoming().updatedAt == request.time;
          
        allow update: if isSignedIn() && (docOwner(existing()) || parentOwner())
          && (incoming().updatedAt == request.time || !('updatedAt' in incoming()) || incoming().updatedAt == existing().updatedAt)
          && (incoming().ownerId == existing().ownerId);

        allow delete: if isSignedIn() && (docOwner(existing()) || parentOwner());
      }
    }
  }
}
